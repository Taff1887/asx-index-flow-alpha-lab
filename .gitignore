# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Environment / secrets
.env
*.key

# Jupyter
.ipynb_checkpoints/

# Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Data policy
# ---------------------------------------------------------------------------
# Raw API pulls and large/blob artefacts are NOT committed (re-fetchable or
# licensed). Manual drop-ins, the registries and processed outputs ARE tracked
# so the research state is reproducible without re-scraping.
data/raw/
data/interim/
*.parquet
*.pdf

# Keep the directory skeleton even when ignoring contents
!data/raw/.gitkeep
!data/raw/**/.gitkeep
!data/interim/.gitkeep

# Track manual ingestion + processed results
!data/manual/
!data/processed/
!reports/

# Figures can get large; keep tables/scorecards, ignore generated pngs by default
reports/figures/*.png
!reports/figures/.gitkeep

# Demo outputs are illustrative (synthetic event set) — regenerate via
# examples/demo_pipeline.py; never commit them as if they were research results.
examples/demo_reports/
examples/demo_work/

# Generated report contents (regenerate from scripts); keep the dir skeleton.
reports/tables/*.csv
reports/scorecards/*.csv

# ...but DO commit the published real-result artefacts shown in reports/README.md
!reports/figures/fig_*.png
!reports/tables/inclusion_strategy_summary.csv
!reports/tables/inclusion_ledger.csv
!reports/tables/inclusion_runup_by_index.csv
!reports/tables/inclusion_runup_by_year.csv
!reports/tables/forced_ownership_map.csv
!reports/tables/asx200_inclusion_events.csv
!reports/tables/asx200_inclusion_ledger.csv
!reports/tables/inclusion_runup_by_liquidity.csv
!reports/tables/flow_scanner.csv
!reports/tables/etf_accumulation.csv
!reports/tables/next_trades_asx_watch.csv
!reports/tables/next_trades_deletion_rebounds.csv
!reports/tables/asx_etf_scanner.csv
!reports/tables/asx_etf_universe.csv
!reports/tables/event_path_caar.csv
!reports/tables/universal_ownership_map.csv
