# Copy to `.env` and fill in. `.env` is git-ignored.

# Financial Modeling Prep (https://site.financialmodelingprep.com/)
# Used for ASX prices, OHLCV, market caps, profiles, sectors, volume/liquidity.
FMP_API_KEY=

# Optional: override the FMP base URL (stable vs legacy v3/v4 endpoints).
FMP_BASE_URL=https://financialmodelingprep.com/api

# Optional: polite default User-Agent for the web client. Some issuer sites
# block default python-requests UAs. Set a real-looking UA if you have
# permission to fetch the page.
WEB_USER_AGENT=asx-index-flow-alpha-lab/0.1 (research; contact: you@example.com)

# Optional: requests-per-minute throttle for the web client (default 20).
WEB_RATE_LIMIT_RPM=20
